// analysis-engine.js -- Fairy-Stockfish WASM wrap, fallback to Wukong on failure
'use strict';

import { boardToFen } from './board.js';

var engine = null;
var fsfReady = false;
var fsfInitPromise = null;
var useFallback = false;
var initTimeout = 8000;
var searchTimeoutPad = 5000;

async function ensureInit() {
  if (fsfReady) return Promise.resolve();
  if (useFallback) return Promise.reject(new Error('fallback'));
  if (fsfInitPromise) return fsfInitPromise;

  fsfInitPromise = new Promise(async function (resolve, reject) {
    var timedOut = false;
    var timer = setTimeout(function () {
      timedOut = true;
      console.warn('[FSF] init timeout (' + initTimeout + 'ms), fallback to Wukong');
      useFallback = true;
      fsfInitPromise = null;
      reject(new Error('FSF init timeout'));
    }, initTimeout);

    try {
      console.log('[FSF] loading WASM...');
      var initFsf = (await import('./engine/fsf_14.js')).default;
      console.log('[FSF] WASM module loaded, instantiating...');
      engine = await initFsf();
      console.log('[FSF] WASM instantiated, starting UCI handshake...');

      if (timedOut) return;

      await new Promise(function (res) {
        var uciTimedOut = false;
        var uciTimer = setTimeout(function () {
          uciTimedOut = true;
          console.warn('[FSF] UCI handshake timeout');
          res();
        }, 5000);

        engine.listen = function (line) {
          console.log('[FSF] UCI:', line);
          if (uciTimedOut) return;
          if (line === 'uciok') {
            console.log('[FSF] got uciok, setting xiangqi mode...');
            engine.uci('setoption name UCI_Variant value xiangqi');
            engine.uci('setoption name Hash value 32');
            engine.uci('isready');
          } else if (line === 'readyok') {
            console.log('[FSF] got readyok, init complete');
            clearTimeout(uciTimer);
            fsfReady = true;
            res();
          }
        };
        engine.uci('uci');
      });

      clearTimeout(timer);
      if (!timedOut) resolve();
    } catch (e) {
      clearTimeout(timer);
      console.warn('[FSF] init failed:', e);
      useFallback = true;
      fsfInitPromise = null;
      reject(e);
    }
  });

  return fsfInitPromise;
}

function parseUciLine(line) {
  if (!line.startsWith('info ')) return null;
  var depth = 0, score = 0, scoreType = 'cp', pv = '';
  var d = line.match(/ depth (\d+)/);
  if (d) depth = parseInt(d[1]);
  var cp = line.match(/ score cp (-?\d+)/);
  var mate = line.match(/ score mate (-?\d+)/);
  if (cp) { scoreType = 'cp'; score = parseInt(cp[1]); }
  else if (mate) { scoreType = 'mate'; score = parseInt(mate[1]); }
  else return null;
  var p = line.match(/ pv (.+)$/);
  if (p) pv = p[1].trim();
  return { scoreType: scoreType, score: score, depth: depth, pv: pv };
}

var wukongAnalyze = null;

async function getWukongAnalyze() {
  if (!wukongAnalyze) {
    var ai = await import('./ai.js');
    wukongAnalyze = ai.analyzePosition;
  }
  return wukongAnalyze;
}

function fsfPvToNative(pv) {
  // FSF UCI: rank 1 = FEN rank 1 = our row 0 (Black back rank)
  // game.js uciToMove expects: rank 1 = our row 9 (Red back rank)
  // Convert: native_rank = 11 - fsf_rank
  if (!pv) return pv;
  return pv.split(' ').map(function(move) {
    var m = move.match(/^([a-i])(\d+)([a-i])(\d+)$/);
    if (!m) return move;
    return m[1] + (11 - parseInt(m[2])) + m[3] + (11 - parseInt(m[4]));
  }).join(' ');
}

export async function analyzePosition(board, color, onUpdate, onDone, thinkTimeMs) {
  // 没有 cross-origin isolation 就直接用 Wukong（FSF 的 pthread 需要 SharedArrayBuffer）
  if (!self.crossOriginIsolated) {
    console.log('[analyze] not cross-origin isolated, using Wukong');
    useFallback = true;
    var wu0 = await getWukongAnalyze();
    wu0(board, color, onUpdate, onDone, thinkTimeMs);
    return;
  }

  if (useFallback) {
    console.log('[analyze] using Wukong engine');
    var wu = await getWukongAnalyze();
    wu(board, color, onUpdate, onDone, thinkTimeMs);
    return;
  }

  if (!fsfReady) {
    try {
      await ensureInit();
    } catch (e) {
      console.log('[analyze] FSF unavailable, fallback to Wukong');
      var wu2 = await getWukongAnalyze();
      wu2(board, color, onUpdate, onDone, thinkTimeMs);
      return;
    }
  }

  if (!fsfReady) {
    console.warn('[analyze] FSF not ready, fallback to Wukong');
    var wu3 = await getWukongAnalyze();
    wu3(board, color, onUpdate, onDone, thinkTimeMs);
    return;
  }

  var fen = boardToFen(board, color);
  var tt = thinkTimeMs || 2000;
  var bestResult = null;
  var doneCalled = false;
  var searchTimer = setTimeout(function () {
    if (!doneCalled) {
      console.warn('[analyze] FSF search timeout, forcing end');
      doneCalled = true;
      if (onDone) onDone(bestResult);
    }
  }, tt + searchTimeoutPad);

  engine.listen = function (line) {
    if (doneCalled) return;
    if (line.startsWith('info ')) {
      var result = parseUciLine(line);
      if (result) {
        var rawPv = result.pv;
        result.pv = fsfPvToNative(result.pv);
        if (rawPv !== result.pv) console.log('[转换] FSF原始PV:', rawPv, '→ 转换后:', result.pv);
        bestResult = result;
        if (onUpdate) onUpdate(result);
      }
    } else if (line.startsWith('bestmove')) {
      clearTimeout(searchTimer);
      doneCalled = true;
      console.log('[analyze] FSF search done:', line);
      if (onDone) onDone(bestResult);
    }
  };

  engine.uci('position fen ' + fen);
  engine.uci('go movetime ' + tt);
}

export function stopEngine() {
  if (engine) engine.uci('stop');
}

export function destroyEngine() {
  engine = null;
  fsfReady = false;
  fsfInitPromise = null;
  useFallback = false;
}
